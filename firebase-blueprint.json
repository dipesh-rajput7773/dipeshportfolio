{
  "entities": {
    "ScriptUsage": {
      "title": "Script Usage",
      "description": "Tracks the number of scripts generated by a user per day.",
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "description": "Number of scripts generated today."
        },
        "lastReset": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the counter was reset."
        }
      },
      "required": ["count", "lastReset"]
    }
  },
  "firestore": {
    "script_usage/{userId}": {
      "schema": "ScriptUsage",
      "description": "Usage tracking for each user."
    }
  }
}
